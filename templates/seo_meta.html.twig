{# SEO meta tags partial - include in <head>
   Usage: {% block seo_meta %}{% include '@MulerTechSeo/seo_meta.html.twig' with { seo: seo } %}{% endblock %}
#}
{% if seo is defined %}
    {% if seo.canonical is defined and seo.canonical %}
        <link rel="canonical" href="{{ seo.canonical }}">
    {% endif %}

    {% if seo['og:title'] is defined and seo['og:title'] %}
        <meta property="og:title" content="{{ seo['og:title'] }}">
    {% endif %}
    {% if seo['og:description'] is defined and seo['og:description'] %}
        <meta property="og:description" content="{{ seo['og:description'] }}">
    {% endif %}
    {% if seo['og:url'] is defined and seo['og:url'] %}
        <meta property="og:url" content="{{ seo['og:url'] }}">
    {% endif %}
    {% if seo['og:type'] is defined and seo['og:type'] %}
        <meta property="og:type" content="{{ seo['og:type'] }}">
    {% endif %}
    {% if seo['og:locale'] is defined and seo['og:locale'] %}
        <meta property="og:locale" content="{{ seo['og:locale'] }}">
    {% endif %}
    {% if seo['og:site_name'] is defined and seo['og:site_name'] %}
        <meta property="og:site_name" content="{{ seo['og:site_name'] }}">
    {% endif %}
    {% if seo['og:image'] is defined and seo['og:image'] %}
        <meta property="og:image" content="{{ seo['og:image'] }}">
    {% endif %}

    {% if seo['article:published_time'] is defined and seo['article:published_time'] %}
        <meta property="article:published_time" content="{{ seo['article:published_time'] }}">
    {% endif %}
    {% if seo['article:modified_time'] is defined and seo['article:modified_time'] %}
        <meta property="article:modified_time" content="{{ seo['article:modified_time'] }}">
    {% endif %}
    {% if seo['article:author'] is defined and seo['article:author'] %}
        <meta property="article:author" content="{{ seo['article:author'] }}">
    {% endif %}

    {% if seo['twitter:card'] is defined and seo['twitter:card'] %}
        <meta name="twitter:card" content="{{ seo['twitter:card'] }}">
    {% endif %}
    {% if seo['twitter:title'] is defined and seo['twitter:title'] %}
        <meta name="twitter:title" content="{{ seo['twitter:title'] }}">
    {% endif %}
    {% if seo['twitter:description'] is defined and seo['twitter:description'] %}
        <meta name="twitter:description" content="{{ seo['twitter:description'] }}">
    {% endif %}
    {% if seo['twitter:image'] is defined and seo['twitter:image'] %}
        <meta name="twitter:image" content="{{ seo['twitter:image'] }}">
    {% endif %}
{% endif %}
